POSTGRES_DB=meeting_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-postgres-password

APP_NAME=AI Meeting Action Tracking System
ENVIRONMENT=production
DATABASE_URL=postgresql://postgres:change-this-postgres-password@postgres:5432/meeting_ai

JWT_SECRET_KEY=change-this-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://YOUR_VM_PUBLIC_IP

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password
DEFAULT_ADMIN_FULL_NAME=System Admin

AI_PROVIDER=vertexai
USE_MOCK_AI=true
GCP_PROJECT_ID=lyrical-link-498907-a2
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

VITE_API_URL=/api
